<UserControl x:Class="DevStrider.Desktop.Views.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
  <DockPanel>
    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Bids per 10 minutes" Style="{StaticResource H1}" VerticalAlignment="Center"/>
      <DatePicker Grid.Column="1" SelectedDate="{Binding SelectedDay, Mode=TwoWay}" Margin="16,0" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="16,0" Foreground="{StaticResource Muted}"/>
      <Button Grid.Column="3"
              Command="{Binding ReloadCommand}"
              Style="{StaticResource IconButton}"
              ToolTip="Refresh"
              Content="&#xE72C;"/>
    </Grid>

    <!-- Owner filter chips -->
    <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding OwnerFilter}" Margin="0,0,0,8">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel/>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <ToggleButton Content="{Binding Owner}"
                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                        Margin="0,0,4,4" Padding="8,2"/>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="6">
      <lvc:CartesianChart x:Name="Chart" Height="360"/>
    </Border>
  </DockPanel>
</UserControl>
