<UserControl x:Class="DevStrider.Desktop.Views.FindBidView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Find bid" Style="{StaticResource H1}" VerticalAlignment="Center"/>
      <TextBox Grid.Column="1"
               Text="{Binding Query, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
               Tag="Search company, role, stack, or URL…"
               Margin="16,0,16,0"
               VerticalAlignment="Center"/>
      <Button Grid.Column="2"
              Command="{Binding SearchCommand}"
              Style="{StaticResource IconButton}"
              ToolTip="Refresh search"
              Content="&#xE721;"/>
    </Grid>
    <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" Foreground="{StaticResource Muted}" Margin="0,0,0,8"/>

    <DataGrid ItemsSource="{Binding Results}">
      <DataGrid.Columns>
        <DataGridTextColumn Header="UID"     Binding="{Binding Bid.ResumeId}" Width="80"/>
        <DataGridTextColumn Header="Company" Binding="{Binding Bid.Company}" Width="*"/>
        <DataGridTextColumn Header="Role"    Binding="{Binding Bid.Role}" Width="*"/>
        <DataGridTextColumn Header="Status"  Binding="{Binding Bid.Status}" Width="120"/>
        <DataGridTextColumn Header="Created" Binding="{Binding Bid.FirstCreatedAt, StringFormat='{}{0:yyyy-MM-dd}'}" Width="100"/>
        <DataGridTextColumn Header="URL"     Binding="{Binding Url}" Width="2*"/>
        <DataGridTemplateColumn Header="Actions" Width="60" CanUserSort="False">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Button Click="OnScheduleClick"
                      Tag="{Binding ., FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                      Style="{StaticResource IconButton}"
                      ToolTip="Schedule interview from this bid"
                      Content="&#xE787;"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
