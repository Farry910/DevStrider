<UserControl x:Class="DevStrider.Desktop.Views.ResumesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Resumes" Style="{StaticResource H1}" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="16,0,0,0"/>
      <Button Grid.Column="2"
              Command="{Binding ReloadCommand}"
              Style="{StaticResource IconButton}"
              ToolTip="Refresh"
              Content="&#xE72C;" Margin="0,0,8,0"/>
      <Button Grid.Column="3" Command="{Binding UploadCommand}">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBlock Text="Upload" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </Grid>

    <TextBlock DockPanel.Dock="Top" Foreground="{StaticResource Muted}" Margin="0,0,0,8"
               Text="File-naming convention: 'UID, Company, Role, Stack1, Stack2, ….pdf' — e.g. '7mK92, Hopper, Senior Front-end Engineer, React, TypeScript, Next.js, Node.js, AWS.pdf'. The UID becomes the link key from a bid (UID column) and from any interview scheduled off that bid."/>

    <DataGrid ItemsSource="{Binding Items}">
      <DataGrid.Columns>
        <DataGridTextColumn Header="UID"      Binding="{Binding Uid}" Width="80"/>
        <DataGridTextColumn Header="Company"  Binding="{Binding Company}" Width="*"/>
        <DataGridTextColumn Header="Role"     Binding="{Binding Role}" Width="*"/>
        <DataGridTextColumn Header="Stacks"   Binding="{Binding Stacks}" Width="2*"/>
        <DataGridTextColumn Header="Uploaded" Binding="{Binding UploadedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
        <DataGridTextColumn Header="File"     Binding="{Binding FileName}" Width="2*"/>
        <DataGridTemplateColumn Header="Actions" Width="90">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <Button Command="{Binding DataContext.DownloadCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding ., FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                        Style="{StaticResource IconButton}"
                        ToolTip="Save to disk"
                        Content="&#xE896;"/>
                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding ., FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                        Style="{StaticResource DangerIconButton}"
                        ToolTip="Delete"
                        Content="&#xE74D;"/>
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
