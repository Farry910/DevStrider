<UserControl x:Class="DevStrider.Desktop.Views.BidBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel LastChildFill="True">
    <!-- Header -->
    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Bid board" Style="{StaticResource H1}" VerticalAlignment="Center"/>
      <DatePicker Grid.Column="1" SelectedDate="{Binding SelectedDay, Mode=TwoWay}" Margin="16,0" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="16,0" Foreground="{StaticResource Muted}"/>
      <Button Grid.Column="3"
              Command="{Binding ReloadCommand}"
              Style="{StaticResource IconButton}"
              ToolTip="Refresh">
        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="14"/>
      </Button>
    </Grid>

    <!-- Add link -->
    <Border DockPanel.Dock="Top" Style="{StaticResource Card}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox Grid.Column="0" Text="{Binding NewLinkUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" Tag="Job URL"/>
        <TextBox Grid.Column="1" Text="{Binding NewLinkSharedJd, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" Tag="Shared JD (optional)"/>
        <Button Grid.Column="2" Command="{Binding AddLinkCommand}" ToolTip="Add link">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Add link" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Rows -->
    <DataGrid ItemsSource="{Binding Rows}" SelectionUnit="FullRow">
      <DataGrid.Columns>
        <DataGridTextColumn Header="URL"        Binding="{Binding Link.Url}" Width="2*"/>
        <DataGridTextColumn Header="Resume"     Binding="{Binding Bid.ResumeId}" Width="100"/>
        <DataGridTextColumn Header="Company"    Binding="{Binding Bid.Company}" Width="*"/>
        <DataGridTextColumn Header="Role"       Binding="{Binding Bid.Role}" Width="*"/>
        <DataGridComboBoxColumn Header="Status"
                                SelectedItemBinding="{Binding Bid.Status}"
                                Width="120">
          <DataGridComboBoxColumn.ItemsSource>
            <x:Array Type="{x:Type System:String}" xmlns:System="clr-namespace:System;assembly=mscorlib">
              <System:String>draft</System:String>
              <System:String>applied</System:String>
              <System:String>phone_screening</System:String>
              <System:String>interview</System:String>
              <System:String>offer</System:String>
              <System:String>rejected</System:String>
              <System:String>withdrawn</System:String>
              <System:String>accepted</System:String>
            </x:Array>
          </DataGridComboBoxColumn.ItemsSource>
        </DataGridComboBoxColumn>
        <DataGridTextColumn Header="Origin"     Binding="{Binding Bid.Origin}" Width="120"/>
        <DataGridTextColumn Header="Created"    Binding="{Binding Bid.FirstCreatedAt, StringFormat='{}{0:MMM dd HH:mm}'}" Width="120"/>
        <DataGridTemplateColumn Header="Actions" Width="120">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <Button Command="{Binding DataContext.SaveBidCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding ., FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                        Style="{StaticResource IconButton}"
                        ToolTip="Save row"
                        Content="&#xE74E;"/>
                <Button Command="{Binding DataContext.ToggleUselessCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding ., FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                        Style="{StaticResource IconButton}"
                        ToolTip="Mark useless"
                        Content="&#xE711;"/>
                <Button Command="{Binding DataContext.DeleteBidCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding ., FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                        Style="{StaticResource DangerIconButton}"
                        ToolTip="Delete bid"
                        Content="&#xE74D;"/>
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
