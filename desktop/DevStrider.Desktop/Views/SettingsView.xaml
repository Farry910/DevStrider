<UserControl x:Class="DevStrider.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="700" HorizontalAlignment="Left">
      <Grid Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Settings" Style="{StaticResource H1}"/>
        <Button Grid.Column="1"
                Command="{Binding SyncFromRegistryCommand}"
                Style="{StaticResource GhostButton}"
                VerticalAlignment="Center"
                ToolTip="Pull Sharing key + Word macro from HKCU\Software\DevStrider into the form (discards unsaved edits to those three fields)">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Sync from registry" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </Grid>
      <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" Margin="0,4,0,12"/>

      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="MongoDB connection" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Text="Connection URI"/>
          <TextBox Text="{Binding Model.MongoUri, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"
                   Tag="mongodb://127.0.0.1:27017"/>
          <TextBlock Text="Database name"/>
          <TextBox Text="{Binding Model.DatabaseName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,4"
                   Tag="devstrider"/>
          <TextBlock Foreground="{StaticResource Muted}"
                     Text="Restart DevStrider after changing these — the connection is created at startup."/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="Identity" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Text="Your username (used as your filename in the team repo)"/>
          <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,4"
                   Tag="e.g. joshua"/>
          <TextBlock Foreground="{StaticResource Muted}"
                     Text="Defaults to your Windows account name (lowercased). Snapshots upload to YYYY-MM-DD/&lt;username&gt;.json. Keep it lowercase, no spaces."/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="Peer database (shared MongoDB / Atlas)" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8" TextWrapping="Wrap"
                     Text="Connection to the shared cluster that holds everyone's bid + interview summaries. Leave blank to disable peer sync. Sync runs from the Sharing tab."/>

          <TextBlock Text="Connection URI"/>
          <TextBox Text="{Binding Model.SharedMongoUri, UpdateSourceTrigger=PropertyChanged}"
                   FontFamily="Consolas"
                   Margin="0,2,0,8"
                   Tag="mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&amp;w=majority"/>

          <TextBlock Text="Database name"/>
          <TextBox Text="{Binding Model.SharedDatabaseName, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,2,0,4"
                   Tag="devstrider-shared"/>
          <TextBlock Foreground="{StaticResource Muted}" TextWrapping="Wrap"
                     Text="Contains two collections — peerBids and peerInterviews. Other collections from older data can be dropped from the Sharing tab's Reset section."/>

          <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button Command="{Binding SaveCommand}" Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Save settings" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Command="{Binding TestSharedConnectionCommand}" Style="{StaticResource GhostButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Test connection" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="Bid-Assistant integration (local HTTP listener)" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8" TextWrapping="Wrap"
                     Text="DevStrider listens on http://127.0.0.1:&lt;port&gt; for POSTs from the Bid-Assistant Chrome extension. Loopback-only — no authentication. Point the extension at this URL and bids you record from ChatGPT land directly in the local Mongo."/>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center" Margin="0,0,8,0">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Background" Value="{StaticResource Muted}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding LocalApi.IsRunning}" Value="True">
                      <Setter Property="Background" Value="{StaticResource OK}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
            </Border>
            <TextBlock Text="{Binding LocalApi.Status}" VerticalAlignment="Center"/>
          </StackPanel>

          <TextBlock Text="Port"/>
          <TextBox Text="{Binding Model.ListenerPort, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,2,0,8" MaxLength="5"
                   Tag="8765"/>

          <StackPanel Orientation="Horizontal">
            <Button Command="{Binding RestartListenerCommand}" Style="{StaticResource GhostButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Restart listener" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>

          <TextBlock Style="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap"
                     Text="Extension contract: POST /record-bid with JSON body { url, jobDescription, gptResumeContent, fastFeedInput?, sharedJobDescription?, comment?, origin? }. Fast-feed format: 'UID, Company, Role, Stack1, Stack2, …' — same as the resume-filename convention."/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="Word macro hotkey" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8" TextWrapping="Wrap"
                     Text="Shared by every profile. The .docm path itself lives per-profile under Profiles (each identity can point at its own macro file)."/>

          <TextBlock Text="Hotkey that triggers the macro"/>
          <TextBox Text="{Binding Model.WordHotkey, UpdateSourceTrigger=PropertyChanged}"
                   Tag="F9   (or Ctrl+Shift+R, etc.)"
                   Margin="0,2,0,4"/>
          <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,0" TextWrapping="Wrap"
                     Text="Default F9 runs Word's 'update fields' macro. Ctrl+S, Ctrl+Shift+R, etc. are accepted. Mirrors to HKCU\Software\DevStrider so it survives a Mongo wipe."/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="Sharing key (group passphrase)" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8" TextWrapping="Wrap"
                     Text="Reserved for a future per-row encryption layer on peer sync. Today peer data goes over TLS to your shared cluster as plaintext; the cluster's access control is the only protection. Set the same value across the team if you plan to opt in later — the fingerprint below makes it easy to confirm a match."/>
          <TextBox Text="{Binding SharingKeyInput, UpdateSourceTrigger=PropertyChanged}"
                   FontFamily="Consolas"
                   Tag="A long, hard-to-guess passphrase your group agrees on"
                   Margin="0,2,0,8"/>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Fingerprint:" Foreground="{StaticResource Muted}" FontSize="11" VerticalAlignment="Center"/>
            <Border Background="{StaticResource SurfaceAlt}" CornerRadius="3" Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
              <TextBlock Text="{Binding SharingKeyFingerprint}"
                         FontFamily="Consolas" FontSize="11"
                         Foreground="{StaticResource Muted}"/>
            </Border>
            <TextBlock Foreground="{StaticResource Muted}" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"
                       Text="(share with teammates out-of-band to confirm everyone's typed the same key)"/>
          </StackPanel>
          <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap"
                     Text="DPAPI-encrypted into HKCU\Software\DevStrider on Save so it survives a Mongo wipe. Pull a registry-edited value back into the form via the Sync button at the top."/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
