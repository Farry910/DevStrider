<UserControl x:Class="DevStrider.Desktop.Views.PeersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <!-- Header + filters -->
    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Peers" Style="{StaticResource H1}" VerticalAlignment="Center"/>
      <DatePicker Grid.Column="1" SelectedDate="{Binding From, Mode=TwoWay}" Margin="16,0,4,0" VerticalAlignment="Center"/>
      <DatePicker Grid.Column="2" SelectedDate="{Binding To, Mode=TwoWay}" Margin="0,0,12,0" VerticalAlignment="Center"/>
      <ComboBox Grid.Column="3"
                ItemsSource="{Binding Owners}"
                SelectedItem="{Binding OwnerFilter, Mode=TwoWay}"
                MinWidth="180"
                VerticalAlignment="Center"
                ToolTip="Filter by peer (empty = show all)"/>
      <TextBlock Grid.Column="4" Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Muted}"/>
      <Button Grid.Column="5"
              Command="{Binding LoadCommand}"
              Style="{StaticResource IconButton}"
              ToolTip="Refresh"
              Content="&#xE72C;"/>
    </Grid>

    <TabControl Background="Transparent" BorderThickness="0">
      <TabItem Header="Bids">
        <DataGrid ItemsSource="{Binding Bids}"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Peer"     Binding="{Binding Username}" Width="120"/>
            <DataGridTextColumn Header="Profile"  Binding="{Binding Profile}"  Width="150"/>
            <DataGridTextColumn Header="Updated"  Binding="{Binding UpdatedAt, StringFormat='{}{0:MMM dd HH:mm}'}" Width="120"/>
            <DataGridTextColumn Header="Company"  Binding="{Binding Company}"  Width="*"/>
            <DataGridTextColumn Header="Role"     Binding="{Binding Role}"     Width="*"/>
            <DataGridTextColumn Header="Status"   Binding="{Binding Status}"   Width="100"/>
            <DataGridTextColumn Header="UID"      Binding="{Binding ResumeId}" Width="80"/>
            <DataGridTextColumn Header="Stacks"   Binding="{Binding Stacks}"   Width="160"/>
            <DataGridTextColumn Header="URL"      Binding="{Binding Url}"      Width="2*"/>
            <DataGridTextColumn Header="Day"      Binding="{Binding DayKey}"   Width="100"/>
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>

      <TabItem Header="Interviews">
        <DataGrid ItemsSource="{Binding Interviews}"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Peer"      Binding="{Binding Username}" Width="120"/>
            <DataGridTextColumn Header="Profile"   Binding="{Binding Profile}"  Width="150"/>
            <DataGridTextColumn Header="Date"      Binding="{Binding ScheduledDate, StringFormat='{}{0:MMM dd yyyy}'}" Width="120"/>
            <DataGridTextColumn Header="Time"      Binding="{Binding ScheduledTime}" Width="70"/>
            <DataGridTextColumn Header="Type"      Binding="{Binding InterviewType}" Width="130"/>
            <DataGridTextColumn Header="Status"    Binding="{Binding Status}"   Width="100"/>
            <DataGridTextColumn Header="Company"   Binding="{Binding Company}"  Width="*"/>
            <DataGridTextColumn Header="Role"      Binding="{Binding Role}"     Width="*"/>
            <DataGridTextColumn Header="Recruiter" Binding="{Binding Recruiter}" Width="140"/>
            <DataGridTextColumn Header="UID"       Binding="{Binding ResumeId}" Width="80"/>
            <DataGridTextColumn Header="Day"       Binding="{Binding DayKey}"   Width="100"/>
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
    </TabControl>
  </DockPanel>
</UserControl>
