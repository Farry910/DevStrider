<UserControl x:Class="DevStrider.Desktop.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Overview" Style="{StaticResource H1}" VerticalAlignment="Center"/>
      <DatePicker Grid.Column="1" SelectedDate="{Binding From, Mode=TwoWay}" Margin="16,0,4,0" VerticalAlignment="Center"/>
      <DatePicker Grid.Column="2" SelectedDate="{Binding To, Mode=TwoWay}" Margin="0,0,16,0" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="3" Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
      <Button Grid.Column="4"
              Command="{Binding ReloadCommand}"
              Style="{StaticResource IconButton}"
              ToolTip="Refresh"
              Content="&#xE72C;"/>
    </Grid>
    <TextBlock DockPanel.Dock="Top" Foreground="{StaticResource Muted}" Margin="0,0,0,8"
               Text="Self + each imported peer. 'Applied' is the sum of non-draft bid statuses in range."/>

    <DataGrid ItemsSource="{Binding Rows}">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Owner"        Binding="{Binding Owner}" Width="*"/>
        <DataGridTextColumn Header="Links"        Binding="{Binding LinksCreated}" Width="80"/>
        <DataGridTextColumn Header="Applied"      Binding="{Binding AppliedCount}" Width="100"/>
        <DataGridTextColumn Header="Interviews"   Binding="{Binding InterviewsInRange}" Width="100"/>
        <DataGridTextColumn Header="Iv passed"    Binding="{Binding InterviewsPassed}" Width="100"/>
        <DataGridTextColumn Header="Iv failed"    Binding="{Binding InterviewsFailed}" Width="100"/>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
