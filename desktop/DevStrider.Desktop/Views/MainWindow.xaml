<Window x:Class="DevStrider.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevStrider"
        Height="780"
        Width="1280"
        Background="{StaticResource Bg}">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
      <StackPanel Margin="12,16">
        <TextBlock Text="DevStrider" FontSize="20" FontWeight="SemiBold" Margin="6,0,0,16"/>
        <Button Content="Bids"        Command="{Binding ShowBidsCommand}"        Margin="0,2" HorizontalAlignment="Stretch"/>
        <Button Content="Interviews"  Command="{Binding ShowInterviewsCommand}"  Margin="0,2" HorizontalAlignment="Stretch"/>
        <Button Content="Overview"    Command="{Binding ShowOverviewCommand}"    Margin="0,2" HorizontalAlignment="Stretch"/>
        <Button Content="Stats"       Command="{Binding ShowStatsCommand}"       Margin="0,2" HorizontalAlignment="Stretch"/>
        <Button Content="Profile"     Command="{Binding ShowProfileCommand}"     Margin="0,2" HorizontalAlignment="Stretch" Style="{StaticResource GhostButton}"/>
        <Button Content="Import peers" Command="{Binding ShowImportCommand}"     Margin="0,2" HorizontalAlignment="Stretch" Style="{StaticResource GhostButton}"/>
        <Button Content="Settings"    Command="{Binding ShowSettingsCommand}"    Margin="0,2" HorizontalAlignment="Stretch" Style="{StaticResource GhostButton}"/>
      </StackPanel>
    </Border>

    <!-- Content -->
    <ContentControl Grid.Column="1" Content="{Binding Current}" Margin="16"/>
  </Grid>
</Window>
