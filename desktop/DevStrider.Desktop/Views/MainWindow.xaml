<Window x:Class="DevStrider.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="DevStrider"
        Icon="pack://application:,,,/Assets/DevStrider.ico"
        Height="780"
        Width="1280"
        MinHeight="540"
        MinWidth="900"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

  <!-- WindowChrome keeps OS features (snap, resize-from-edges, Win11 thumbnails) while
       letting us paint the entire window ourselves. CaptionHeight defines the draggable
       strip at the top; ResizeBorderThickness is the invisible 6px hot-zone for resizing. -->
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="36"
                        CornerRadius="0"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="6"
                        UseAeroCaptionButtons="False"/>
  </shell:WindowChrome.WindowChrome>

  <Border x:Name="RootBorder"
          Background="{StaticResource Bg}"
          BorderBrush="{StaticResource Border}"
          BorderThickness="1"
          CornerRadius="5">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="36"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- ===== Title bar (spans both columns) ===== -->
      <Border x:Name="TitleBarBorder"
              Grid.ColumnSpan="2"
              Background="{StaticResource Surface}"
              BorderBrush="{StaticResource BorderSoft}"
              BorderThickness="0,0,0,1"
              CornerRadius="5,5,0,0">
        <DockPanel LastChildFill="True">
          <!-- Caption buttons (must opt out of WindowChrome hit-test) -->
          <StackPanel DockPanel.Dock="Right"
                      Orientation="Horizontal"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button x:Name="MinBtn"
                    Style="{StaticResource CaptionButton}"
                    Content="&#xE921;"
                    ToolTip="Minimize"
                    Click="OnMinimizeClick"/>
            <Button x:Name="MaxBtn"
                    Style="{StaticResource CaptionButton}"
                    Content="&#xE922;"
                    ToolTip="Maximize"
                    Click="OnMaximizeClick"/>
            <Button x:Name="CloseBtn"
                    Style="{StaticResource CaptionCloseButton}"
                    Content="&#xE8BB;"
                    ToolTip="Close"
                    Click="OnCloseClick"/>
          </StackPanel>

          <!-- Brand area on the left (left blank intentionally; drag works anywhere here) -->
          <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
            <Border Width="14" Height="14" CornerRadius="3" Background="{StaticResource Primary}" Margin="0,0,8,0"/>
            <TextBlock Text="DevStrider" FontWeight="SemiBold" FontSize="13"/>
            <TextBlock Text=" · local"
                       Foreground="{StaticResource Muted}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"/>
            <!-- Version pill — eyeball whether the build is up to date. -->
            <Border Background="{StaticResource SurfaceAlt}"
                    CornerRadius="3"
                    Padding="6,1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding Version}"
                         Foreground="{StaticResource Muted}"
                         FontSize="11"/>
            </Border>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ===== Sidebar (icon + label rows) ===== -->
      <Border x:Name="SidebarBorder"
              Grid.Row="1" Grid.Column="0"
              Background="{StaticResource Surface}"
              BorderBrush="{StaticResource BorderSoft}"
              BorderThickness="0,0,1,0"
              CornerRadius="0,0,0,5">
        <DockPanel LastChildFill="False" Margin="10,14">
          <!-- Primary nav -->
          <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="WORKSPACE"
                       Style="{StaticResource MutedText}"
                       FontWeight="SemiBold"
                       FontSize="10"
                       Margin="14,4,0,8"/>
            <Button Command="{Binding ShowBidsCommand}" Style="{StaticResource NavButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Bids" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Command="{Binding ShowInterviewsCommand}" Style="{StaticResource NavButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Interviews" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Command="{Binding ShowOverviewCommand}" Style="{StaticResource NavButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Overview" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Command="{Binding ShowStatsCommand}" Style="{StaticResource NavButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Stats" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- Secondary nav at the bottom -->
          <StackPanel DockPanel.Dock="Bottom">
            <Border Background="{StaticResource BorderSoft}" Height="1" Margin="6,8" SnapsToDevicePixels="True"/>
            <TextBlock Text="ACCOUNT"
                       Style="{StaticResource MutedText}"
                       FontWeight="SemiBold"
                       FontSize="10"
                       Margin="14,4,0,8"/>
            <Button Command="{Binding ShowResumesCommand}" Style="{StaticResource NavButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Resumes" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Command="{Binding ShowImportCommand}" Style="{StaticResource NavButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Import peers" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Command="{Binding ShowSettingsCommand}" Style="{StaticResource NavButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Settings" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ===== Content area ===== -->
      <Border x:Name="ContentBorder"
              Grid.Row="1" Grid.Column="1"
              Background="{StaticResource Bg}"
              CornerRadius="0,0,5,0">
        <ContentControl Content="{Binding Current}" Margin="22"/>
      </Border>
    </Grid>
  </Border>
</Window>
