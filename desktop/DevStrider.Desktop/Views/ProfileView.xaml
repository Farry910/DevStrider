<UserControl x:Class="DevStrider.Desktop.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="0,0,0,16" MaxWidth="820" HorizontalAlignment="Left">
      <TextBlock Text="Resume profile" FontSize="20" FontWeight="SemiBold"/>
      <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Muted}" Margin="0,4,0,12"/>

      <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="Header" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Text="Display name"/>
          <TextBox Text="{Binding Profile.DisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>
          <TextBlock Text="Headline"/>
          <TextBox Text="{Binding Profile.Headline, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,4,0">
              <TextBlock Text="Location"/>
              <TextBox Text="{Binding Profile.Location, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="4,0,0,0">
              <TextBlock Text="Phone"/>
              <TextBox Text="{Binding Profile.Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>
            </StackPanel>
          </Grid>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,4,0">
              <TextBlock Text="Personal email"/>
              <TextBox Text="{Binding Profile.PersonalEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="4,0,0,0">
              <TextBlock Text="LinkedIn URL"/>
              <TextBox Text="{Binding Profile.LinkedinUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
        <StackPanel>
          <DockPanel LastChildFill="False" Margin="0,0,0,4">
            <TextBlock Text="Experiences" FontWeight="SemiBold" VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <Button Content="Add" Command="{Binding AddExperienceCommand}" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
          </DockPanel>
          <TextBlock Foreground="{StaticResource Muted}" Margin="0,0,0,8"
                     Text="Role/title for each entry is captured from the bid body's [Subtitle N] line. Order matters."/>
          <ItemsControl ItemsSource="{Binding Experiences}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,0,0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0" Margin="0,0,4,0" Text="{Binding Company, UpdateSourceTrigger=PropertyChanged}" Tag="Company"/>
                  <TextBox Grid.Column="1" Margin="0,0,4,0" Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" Tag="Location"/>
                  <TextBox Grid.Column="2" Margin="0,0,4,0" Text="{Binding StartYear, UpdateSourceTrigger=PropertyChanged}" Tag="From"/>
                  <TextBox Grid.Column="3" Margin="0,0,4,0" Text="{Binding EndYear, UpdateSourceTrigger=PropertyChanged}" Tag="To"/>
                  <Button Grid.Column="4" Content="Remove"
                          Command="{Binding DataContext.RemoveExperienceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" Style="{StaticResource GhostButton}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
        <StackPanel>
          <DockPanel LastChildFill="False" Margin="0,0,0,4">
            <TextBlock Text="Education" FontWeight="SemiBold" VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <Button Content="Add" Command="{Binding AddEducationCommand}" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
          </DockPanel>
          <ItemsControl ItemsSource="{Binding Education}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,0,0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0" Margin="0,0,4,0" Text="{Binding Degree, UpdateSourceTrigger=PropertyChanged}" Tag="Degree"/>
                  <TextBox Grid.Column="1" Margin="0,0,4,0" Text="{Binding School, UpdateSourceTrigger=PropertyChanged}" Tag="School"/>
                  <TextBox Grid.Column="2" Margin="0,0,4,0" Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" Tag="Location"/>
                  <TextBox Grid.Column="3" Margin="0,0,4,0" Text="{Binding StartYear, UpdateSourceTrigger=PropertyChanged}" Tag="From"/>
                  <TextBox Grid.Column="4" Margin="0,0,4,0" Text="{Binding EndYear, UpdateSourceTrigger=PropertyChanged}" Tag="To"/>
                  <Button Grid.Column="5" Content="Remove"
                          Command="{Binding DataContext.RemoveEducationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" Style="{StaticResource GhostButton}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
        <StackPanel>
          <DockPanel LastChildFill="False" Margin="0,0,0,4">
            <TextBlock Text="Certifications" FontWeight="SemiBold" VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <Button Content="Add" Command="{Binding AddCertificationCommand}" Style="{StaticResource GhostButton}" DockPanel.Dock="Right"/>
          </DockPanel>
          <ItemsControl ItemsSource="{Binding Certifications}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,0,0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBox Grid.Column="0" Margin="0,0,4,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Tag="Name"/>
                  <TextBox Grid.Column="1" Margin="0,0,4,0" Text="{Binding Issuer, UpdateSourceTrigger=PropertyChanged}" Tag="Issuer"/>
                  <TextBox Grid.Column="2" Margin="0,0,4,0" Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" Tag="Year"/>
                  <Button Grid.Column="3" Content="Remove"
                          Command="{Binding DataContext.RemoveCertificationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" Style="{StaticResource GhostButton}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Button Content="Save profile" Command="{Binding SaveCommand}" HorizontalAlignment="Left" Padding="16,6"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
