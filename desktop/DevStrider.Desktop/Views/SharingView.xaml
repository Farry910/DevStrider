<UserControl x:Class="DevStrider.Desktop.Views.SharingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="760" HorizontalAlignment="Left">
      <TextBlock Text="Peer sync" Style="{StaticResource H1}"/>
      <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" Margin="0,4,0,12"/>

      <!-- Sync card -->
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="Sync with shared cluster" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8" TextWrapping="Wrap"
                     Text="Sync uploads your bids + interviews updated since the last run, and downloads everyone else's. Only company / role / status / stacks / dates are shared — URLs, JDs, GPT content, and comments stay private to you."/>

          <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="140"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Last sync" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding LastSyncDisplay}" FontFamily="Consolas" VerticalAlignment="Center"/>
          </Grid>

          <StackPanel Orientation="Horizontal">
            <Button Command="{Binding SyncCommand}"
                    IsEnabled="{Binding IsConfigured}"
                    Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Sync now" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Command="{Binding LoadCommand}" Style="{StaticResource GhostButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Refresh status" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Reset card -->
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="Reset shared database" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,8" TextWrapping="Wrap"
                     Text="Tick anything left over from the old web app and drop it. peerBids and peerInterviews are protected — DevStrider needs them."/>

          <DataGrid ItemsSource="{Binding RemoteCollections}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    HeadersVisibility="Column"
                    Margin="0,0,0,8"
                    MaxHeight="280">
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="" Width="40" CanUserSort="False">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox IsChecked="{Binding SelectedForDrop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                      <CheckBox.Style>
                        <Style TargetType="CheckBox">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsKept}" Value="True">
                              <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </CheckBox.Style>
                    </CheckBox>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Collection" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
              <DataGridTextColumn Header="Docs"       Binding="{Binding DocumentCount}" Width="100" IsReadOnly="True"/>
              <DataGridTextColumn Header="Protected"  Binding="{Binding IsKept}" Width="100" IsReadOnly="True"/>
            </DataGrid.Columns>
          </DataGrid>

          <StackPanel Orientation="Horizontal">
            <Button Command="{Binding LoadRemoteCollectionsCommand}" Style="{StaticResource GhostButton}" Margin="0,0,8,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Refresh list" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Command="{Binding DropSelectedCollectionsCommand}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource Danger}"/>
                <TextBlock Text="Drop selected" VerticalAlignment="Center" Foreground="{StaticResource Danger}"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
