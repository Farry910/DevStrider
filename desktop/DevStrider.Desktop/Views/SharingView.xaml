<UserControl x:Class="DevStrider.Desktop.Views.SharingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Sharing" Style="{StaticResource H1}" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Muted}"/>
      <Button Grid.Column="2"
              Command="{Binding LoadCommand}"
              Style="{StaticResource IconButton}"
              ToolTip="Refresh"
              Content="&#xE72C;"
              Margin="0,0,8,0"/>
      <Button Grid.Column="3" Command="{Binding PushTodayCommand}">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBlock Text="Push today's snapshot" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </Grid>

    <Border DockPanel.Dock="Top" Style="{StaticResource Card}">
      <StackPanel>
        <TextBlock Text="Today" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding TodayStatus}" Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>
        <TextBlock Style="{StaticResource MutedText}" Margin="0,8,0,0" TextWrapping="Wrap"
                   Text="Pushes go to YYYY-MM-DD/{username}.json in the team repo. When a sharing key is set in Settings, the snapshot is AES-GCM-encrypted before push; peers decrypt with the same key on import."/>
      </StackPanel>
    </Border>

    <DataGrid ItemsSource="{Binding Items}">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Day"        Binding="{Binding DayKey}" Width="120"/>
        <DataGridTextColumn Header="Pushed at"  Binding="{Binding PushedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="180"/>
        <DataGridTextColumn Header="Path"       Binding="{Binding RepoPath}" Width="2*"/>
        <DataGridTextColumn Header="Encrypted" Binding="{Binding Encrypted}" Width="100"/>
        <DataGridTextColumn Header="Success"    Binding="{Binding Success}" Width="80"/>
        <DataGridTextColumn Header="Message"    Binding="{Binding Message}" Width="*"/>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
