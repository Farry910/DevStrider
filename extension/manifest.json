{
  "manifest_version": 3,
  "name": "Bid Assistant",
  "version": "2.1.0",
  "description": "Extract JD from job page, paste into ChatGPT, and record the bid in the local DevStrider desktop app.",
  "icons": { "16": "icon.png", "48": "icon.png", "128": "icon.png" },
  "permissions": ["activeTab", "scripting", "storage", "tabs", "windows"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8765/*"],
  "action": { "default_popup": "popup.html" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content.js"], "run_at": "document_idle" }
  ]
}
