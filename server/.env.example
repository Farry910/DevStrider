PORT=4000
# Listen address. 0.0.0.0 = all interfaces (reachable via LAN / your static IP). Use 127.0.0.1 to block remote access.
HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017/devstrider
JWT_SECRET=change-me-to-a-long-random-string
# Browser origin(s) for CORS + Socket.IO — must match the URL users type in the address bar (scheme + host + port).
# Vite dev (npm run dev): http://localhost:5173
# Server-only with built client (npm run build && npm run start): e.g. http://YOUR_STATIC_IP:4000 or http://localhost:4000
# Comma-separated to allow multiple (e.g. localhost + LAN): http://localhost:4000,http://192.168.1.10:4000
CLIENT_ORIGIN=http://localhost:5173

# Bid Assistant: uses the same JWT as the web app (localStorage devstrider_token). Optional CORS helpers:
# BID_ASSISTANT_EXTENSION_ID=
# CORS_EXTRA_ORIGINS=
# Optional MongoDB driver tuning (see server/src/config/db.js)
# MONGODB_MAX_POOL_SIZE=20
# MONGODB_MIN_POOL_SIZE=2
# MONGODB_SERVER_SELECTION_MS=10000
# MONGODB_SOCKET_TIMEOUT_MS=45000
