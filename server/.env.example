PORT=4000
# Listen address. 0.0.0.0 = all interfaces (reachable via LAN / your static IP). Use 127.0.0.1 to block remote access.
# On Render, leave HOST and PORT unset — the platform injects PORT and requires 0.0.0.0.
HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017/devstrider
JWT_SECRET=change-me-to-a-long-random-string
# Browser origin(s) for CORS + Socket.IO — must match the URL users type in the address bar (scheme + host + port).
# Vite dev: http://localhost:5173
# Netlify-hosted client: https://<your-site>.netlify.app
# Comma-separated to allow multiple: https://app.netlify.app,https://staging.netlify.app
CLIENT_ORIGIN=http://localhost:5173

# Bid Assistant: the local Bid Assistant app makes server-side HTTP calls to /api/integrations/bid-assistant/*
# and forwards the user's JWT (Authorization: Bearer <token>). No CORS entry is needed because the call is
# not browser-originated. The Chrome extension only talks to the local Bid Assistant app, never to this server.

# Optional: any additional browser origins that need CORS (preview deploys, alternate domains).
# CORS_EXTRA_ORIGINS=

# Optional MongoDB driver tuning (see server/src/config/db.js)
# MONGODB_MAX_POOL_SIZE=20
# MONGODB_MIN_POOL_SIZE=2
# MONGODB_SERVER_SELECTION_MS=10000
# MONGODB_SOCKET_TIMEOUT_MS=45000
